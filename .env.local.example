# Copy to .env.local and fill in.

# Repo whose stars grow the tree (defaults to valenbine/Tree3D).
# GITHUB_REPO=valenbine/Tree3D

# Personal access token (classic, public_repo scope is enough) for higher rate
# limits. Read server-side only — never exposed to the browser.
# GITHUB_TOKEN=ghp_xxx

# Fallback star count shown when the repo doesn't exist yet / API fails.
# DEMO_STARS=8

# Show the in-scene +/- star editor (dev/preview only). Leave unset in
# production so visitors only ever see the real GitHub star count.
# NEXT_PUBLIC_DEV_CONTROLS=true

# Secret that protects the background refresh route (/api/cron/stargazers).
# Set the SAME value in the Vercel project env — Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>`. If unset, the route is open (fine for
# local dev). Generate one with: openssl rand -hex 32
# CRON_SECRET=xxxx
